model User {
  id           String       @id @default(uuid())
  name         String       @db.VarChar(255)
  email        String       @unique
  password     String

  activeStatus ActiveStatus @default(active)
  role         Role         @default(user)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  
  profile      Profile?
  posts        Post[]
  comments     Comment[]

  @@map("users")
}

